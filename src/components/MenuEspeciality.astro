---
const {title} = Astro.props;
---

<li class="relative max-w-[188px] font-sans font-regular text-base leading-base text-black-800">
    <a href="#" class="flex flex-row items-center gap-2 py-1 px-3 w-full hover:text-secondary-500 transition-all font-sans font-normal">
        <span>
            <slot />
        </span>
        {title}
    </a>
</li>
